  "AI_COMPONENTS": {
    "satellite_imagery_analysis": {
      "provider": "Planet Labs API",
      "integration": "PlanetLabsClient service",
      "process": [
        "Request satellite imagery for parcel polygon",
        "Extract NIR (Near-Infrared) and Red bands",
        "Compute NDVI: (NIR - Red) / (NIR + Red)",
        "Classify pixels as stressed/healthy",
        "Generate visualization heatmap"
      ],
      "output": "NDVI values (-1 to 1), stress classification, heatmap"
    },
    "ndvi_computation": {
      "service": "NDVIService",
      "algorithm": "NDVI = (NIR - Red) / (NIR + Red)",
      "normalization": "0 to 1 scale for visualization",
      "stress_classification": {
        "HIGH": "NDVI ≤ 0.35",
        "MEDIUM": "NDVI 0.35-0.45",
        "HEALTHY": "NDVI > 0.45"
      },
      "output": "Pixel-level stress map with coordinates"
    },
    "disease_detection": {
      "provider": "Hugging Face API",
      "integration": "DiseaseDetectionService",
      "model_type": "Image classification model for plant diseases",
      "process": [
        "User uploads crop image",
        "Image sent to Hugging Face endpoint",
        "AI model classifies disease type",
        "Confidence score returned (0-100%)",
        "Rule-based recommendations generated"
      ],
      "output": "Disease name, confidence, treatment recommendations"
    },
    "conversational_ai": {
      "provider": "Google Gemini LLM",
      "integration": "ChatbotService with LLMService",
      "architecture": "Tool-calling agent",
      "process": [
        "User sends natural language query",
        "Gemini processes and identifies intent",
        "Route to appropriate tool (getStress, getIrrigation, etc.)",
        "Tool executes and returns data",
        "Gemini synthesizes response with context",
        "Multi-language response generation"
      ],
      "supported_tools": [
        "getStress(parcelId)",
        "getIrrigationStatus(parcelId)",
        "getCropCalendar(parcelId)",
        "detectDisease(image)"
      ],
      "languages": ["English", "French", "Arabic"]
    },
    "weather_integration": {
      "provider": "Open-Meteo API (free, no API key)",
      "integration": "IrrigationService",
      "data_points": [
        "Current temperature",
        "Rainfall forecast",
        "Humidity",
        "Wind speed",
        "Solar radiation"
      ],
      "usage": "ETc calculation adjustment, irrigation scheduling"
    },
    "intelligent_irrigation": {
      "algorithm": "ETc-based with multi-factor adjustment",
      "formula": "Water Needed = ETo × Kc × StressAdjustment × HumidityAdjustment",
      "data_inputs": [
        "Reference evapotranspiration (ETo)",
        "Crop coefficient (Kc) from stage",
        "Stress percentage from stress analysis",
        "Humidity from weather API",
        "Rainfall forecast"
      ],
      "decision_levels": ["LOW", "MEDIUM", "HIGH priority"],
      "output": "Irrigation schedule, water amount, timing"
    }
  },

