# Configuration for Stress Service Validation Agent

# Service URLs
STRESS_SERVICE_URL=http://localhost:3005
CROP_CALENDAR_SERVICE_URL=http://localhost:3002

# Test Configuration
TEST_PARCEL_IDS=1,2,3,4,5

# Validation Parameters
NDVI_PRECISION_DECIMALS=4
PERCENTAGE_PRECISION=2

# Timeouts (in milliseconds)
API_TIMEOUT=30000

# Logging
LOG_LEVEL=info
VERBOSE=false

# Validation Rules
# NDVI Classification thresholds
NDVI_HIGH_STRESS_THRESHOLD=0.35
NDVI_MEDIUM_STRESS_THRESHOLD=0.45
NDVI_HEALTHY_THRESHOLD=0.45

# Stress percentage thresholds for alerts
STRESS_ALERT_HIGH_THRESHOLD=45
STRESS_ALERT_MEDIUM_THRESHOLD=30
STRESS_ALERT_LOW_THRESHOLD=15

# Cloud coverage tolerance
MAX_CLOUD_COVERAGE=50

# Geospatial validation
MIN_POLYGON_POINTS=4
COORDINATE_PRECISION=6

# Report generation
GENERATE_REPORT=true
REPORT_PATH=./tests/validation-reports/
REPORT_FORMAT=json
