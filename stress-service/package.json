{
  "name": "stress-service",
  "version": "1.0.0",
  "description": "Smart Agriculture Vegetation Stress Detection Microservice",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrations": "node db/migrations.js",
    "seed-db": "node db/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "validate": "node validate-stress-output.js",
    "validate:verbose": "node validate-stress-output.js --verbose",
    "validate:watch": "node validate-stress-output.js && npm run validate:watch"
